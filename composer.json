{
	"name": "celemas/sire",
	"description": "A PHP validation library",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@celemas.dev"
		}
	],
	"homepage": "https://celemas.dev/sire",
	"keywords": [
		"celemas",
		"validation"
	],
	"autoload": {
		"psr-4": {
			"Celemas\\Sire\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Celemas\\Sire\\Tests\\": "tests"
		}
	},
	"require": {
		"php": "^8.5",
		"symfony/html-sanitizer": "^8.0"
	},
	"require-dev": {
		"celemas/dev": "^4.2"
	},
	"scripts": {
		"test": "./vendor/bin/phpunit --testdox --no-coverage --colors=always",
		"types": "./vendor/bin/psalm --no-cache",
		"lint": [
			"./vendor/bin/mago fmt --check",
			"./vendor/bin/mago lint"
		],
		"docs:format": "npx prettier@3.6.2 --write --config ./docs/.prettierrc README.md CHANGELOG.md LICENSE.md docs/",
		"docs:lint": "npx markdownlint-cli2@0.22.1 --config ./vendor/celemas/dev/config/markdownlint.jsonc README.md CHANGELOG.md LICENSE.md docs/",
		"coverage:test": "php -d xdebug.mode=coverage ./vendor/bin/phpunit --testdox --path-coverage --colors=always",
		"coverage:analyze": "./vendor/bin/coverlyzer .coverage/coverage.php",
		"coverage": [
			"composer coverage:test",
			"composer coverage:analyze"
		],
		"ci": [
			"composer lint",
			"composer coverage",
			"composer types",
			"composer docs:lint"
		]
	}
}
